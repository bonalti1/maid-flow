# Maid Flow server configuration.
# Copy this file to server/.env and fill in the keys you have.
# Any key you leave blank keeps that feature in demo mode (simulated data).
# Full catalog with notes: /playbook/05-env.md

# ── Portal access (secrets — pick long, unique values) ──
# Gate /admin (everything), /closer + /onboarding, and /cs. ADMIN_KEY also
# opens /closer and /cs.
ADMIN_KEY=
CLOSER_KEY=
CS_KEY=

# ── Data ──
# Postgres connection string (Supabase). Leave blank for a local JSON file
# store (DEV ONLY — wiped on every deploy). In production, if this is set but
# unreachable, the server refuses to start (never falls back to the file).
DATABASE_URL=
# Set REQUIRE_DB=1 in production to also refuse to start when DATABASE_URL is
# missing entirely (guards against silently running on the ephemeral file store).
REQUIRE_DB=

# ── Money (Stripe) ──
# Payment Link + webhook signing secret. Configure the webhook at
# /api/stripe/webhook. Regenerate the link with client_reference_id = the
# contractor id for deterministic matching.
STRIPE_WEBHOOK_SECRET=
# 3-tier ladder — one Payment Link per plan. The webhook tags the plan by the
# exact amount paid ($67 pro / $197 widget / $297 complete). STRIPE_PAYMENT_LINK
# is the legacy single link (still honored as the COMPLETE fallback).
STRIPE_LINK_PRO=
STRIPE_LINK_WIDGET=
STRIPE_LINK_COMPLETE=
STRIPE_PAYMENT_LINK=

# ── Product APIs (blank = demo mode) ──
# Anthropic — the AI assistant (site bots, onboarding copywriter, advisor).
ANTHROPIC_API_KEY=
# OpenAI — assistant fallback.
OPENAI_API_KEY=
OPENAI_MODEL=
# Google Maps — server-side Places (address autocomplete) + Geocoding.
# Enable "Places API" and "Geocoding API" on the key.
GOOGLE_MAPS_API_KEY=
# A domain-restricted browser key for the in-app map (never falls back to the
# server key above).
GOOGLE_MAPS_BROWSER_KEY=
# RentCast — property data (beds/baths/sq ft). Without it the widget asks the
# homeowner for approximate square footage. Free tier: 50 lookups/month.
RENTCAST_API_KEY=

# ── Client domains (Cloudflare) ──
CF_API_TOKEN=
CF_ZONE_ID=
CF_CNAME_TARGET=

# ── Host / marketing ──
# This business's own domain. LEAVE BLANK and everything serves on the
# onrender/localhost host. Set ROOT_DOMAIN once DNS is live (e.g. maidflow.com)
# to turn on the bare-domain sales page, <slug>.ROOT_DOMAIN client subdomains,
# and canonical links. APP_HOST is where the app/dashboard lives.
ROOT_DOMAIN=
APP_HOST=
# Shared secret for the GHL → engine bridge (POST /api/hl/lead, header x-alto-key).
HL_WEBHOOK_SECRET=

# ── Web push (lead buzz) ──
# Generate once: npx web-push generate-vapid-keys. Dormant until both are set.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
# Meta Pixel id for public pages.
META_PIXEL_ID=

# ── Vestigial ──
# Only read by /api/diag (the parcel/roof code was removed).
REGRID_API_KEY=

# ── Local dev ──
# PORT is injected by Render in production.
PORT=
